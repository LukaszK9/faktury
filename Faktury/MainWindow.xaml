<Window x:Class="Faktury.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Faktur" Height="600" Width="1000">

    <Grid Background="#F0F0F0">

        <TabControl Background="White" Margin="10">

            <TabItem Header="Faktury" x:Name="Tab_Faktury">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        
                        <TextBlock Text="Nr Faktury:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Width="100" Margin="10,0,20,0" Padding="2" />
                        
                        <TextBlock Text="Klient:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <ComboBox Width="150" Margin="10,0,20,0"/>

                        <TextBlock Text="Data Wystawienia:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <DatePicker Width="120" Margin="10,0,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="Invoice_DataGrid" AutoGenerateColumns="False" CanUserAddRows="True" AlternatingRowBackground="#F9F9F9" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Nazwa}" Width="*"/>
                            <DataGridTextColumn Header="Ilość" Binding="{Binding Ilosc}" Width="70"/>
                            <DataGridTextColumn Header="Jednostka miary" Binding="{Binding JednostkaMiary}" Width="110"/>
                            <DataGridTextColumn Header="CENA NETTO" Binding="{Binding CenaNetto}" Width="100"/>
                            <DataGridTextColumn Header="CENA BRUTTO" Binding="{Binding CenaBrutto}" Width="100"/>
                            <DataGridTextColumn Header="VAT" Binding="{Binding Vat}" Width="60"/>
                            
                            <DataGridTextColumn Header="WARTOŚĆ NETTO" Binding="{Binding WartoscNetto}" Width="120"/>
                            <DataGridTextColumn Header="WARTOŚĆ BRUTTO" Binding="{Binding WartoscBrutto}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Dodaj Pozycję" Width="120" Padding="5" Margin="0,0,10,0"/>
                        <Button Content="Zapisz Fakturę" Width="120" Padding="5" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Klienci" x:Name="Tab_Klienci">
                <Grid>
                    <TextBlock Text="Klienci" FontSize="20" Foreground="Gray" Margin="10,10,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Produkty" x:Name="Tab_Produkty">
                <Grid>
                    <TextBlock Text="Produkty" FontSize="20" Foreground="Gray" Margin="10,10,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Koszty" x:Name="Tab_Koszty">
                <Grid>
                    <TextBlock Text="Koszty" FontSize="20" Foreground="Gray" Margin="10,10,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Raporty" x:Name="Tab_Raporty">
                <Grid>
                    <TextBlock Text="Raporty" FontSize="20" Foreground="Gray" Margin="10,10,0,0"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>