<Window x:Class="Faktury.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Faktur" Height="600" Width="1000">

    <Grid Background="#F0F0F0">

        <TabControl Background="White" Margin="10">

            <TabItem Header="Faktury" x:Name="Tab_Faktury">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Text="Dodaj Pozycję" VerticalAlignment="Center" Margin="0,0,0,10" FontWeight="Bold"/>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Wybierz produkt:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="Input_InvoiceItemName" Width="220" Margin="0,0,20,10"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Ilość:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="0" Grid.Column="3" x:Name="Input_InvoiceItemCount" Margin="0,0,0,10" Padding="3"/>

                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
                                <Button Content="Wyczyść Formularz" Width="130" Padding="6" Margin="0,0,10,0" Background="#F0F0F0" Click="CleanInvoiceProductForm_Click"/>
                                <Button Content="Dodaj Pozycję" Width="120" Padding="5" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="AddInvoiceProduct_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="Invoice_DataGrid" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Ilość" Binding="{Binding Count}" Width="70"/>
                            <DataGridTextColumn Header="Jednostka miary" Binding="{Binding Unit}" Width="110"/>
                            <DataGridTextColumn Header="CENA NETTO" Binding="{Binding PriceNetto}" Width="100"/>
                            <DataGridTextColumn Header="CENA BRUTTO" Binding="{Binding PriceBrutto}" Width="100"/>
                            <DataGridTextColumn Header="VAT%" Binding="{Binding Vat}" Width="60"/>
                            
                            <DataGridTextColumn Header="WARTOŚĆ NETTO" Binding="{Binding ValueNetto}" Width="120"/>
                            <DataGridTextColumn Header="WARTOŚĆ BRUTTO" Binding="{Binding ValueBrutto}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>


                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">

                        <TextBlock Text="Nr Faktury:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBox Width="100" Margin="10,0,20,0" Padding="2"/>

                        <TextBlock Text="Klient:" VerticalAlignment="Center" FontWeight="Bold"/>
                        <ComboBox x:Name="Input_InvoiceClientName" Width="150" Margin="10,0,20,0"/>

                        <TextBlock Text="Data Wystawienia:" VerticalAlignment="Center" FontWeight="Bold" />
                        <DatePicker Width="120" Margin="10,0,20,0"/>

                        <Button Content="Zapisz Fakturę" Width="120" Padding="5" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="10,0,0,0" Click="SaveInvoice_Click"/>
                        <Button Content="Nowa faktura" Width="120" Margin="10,0,0,0" Click="NewInvoice_Click"/>

                    </StackPanel>

                </Grid>
            </TabItem>

            <TabItem Header="Klienci" x:Name="Tab_Klienci">
                <Grid Margin="15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Text="Dodaj Klienta" VerticalAlignment="Center" Margin="0,0,0,10" FontWeight="Bold"/>

                            <Grid Grid.Row="1" Margin="0,0,0,10">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nazwa Firmy / Imię i Nazwisko:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="Input_ClientName" Margin="0,0,20,10" Padding="3"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="NIP:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="0" Grid.Column="3" x:Name="Input_ClientNIP" Margin="0,0,0,10" Padding="3"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Adres:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="Input_ClientAdress" Margin="0,0,20,0" Padding="3"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Email / Telefon:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="1" Grid.Column="3" x:Name="Input_ClientContact" Margin="0,0,0,0" Padding="3"/>

                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Wyczyść Formularz" Width="130" Padding="6" Margin="0,0,10,0" Background="#F0F0F0" Click="CleanClientForm_Click"/>
                                <Button Content="Dodaj Klienta" Width="120" Padding="5" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="AddClient_Click"/>
                            </StackPanel>

                        </Grid>

                    </Border>


                    <DataGrid Grid.Row="1" x:Name="Clients_DataGrid" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="NIP" Binding="{Binding Nip}" Width="120"/>
                            <DataGridTextColumn Header="Adres" Binding="{Binding Adress}" Width="*"/>
                            <DataGridTextColumn Header="Kontakt" Binding="{Binding Contact}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

            <TabItem Header="Produkty" x:Name="Tab_Produkty">
                <Grid Margin="15">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Formularz -->
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="15" Margin="0,0,0,10" CornerRadius="5">
                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" FontSize="16" Text="Dodaj Produkt" Margin="0,0,0,10" FontWeight="Bold"/>

                            <Grid Grid.Row="1" Margin="0,0,0,10">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nazwa:" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="Input_ProductName" Margin="0,0,20,10" Padding="3"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Jednostka:" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="0" Grid.Column="3" x:Name="Input_ProductUnit" Margin="0,0,0,10" Padding="3"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Cena Netto:" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="Input_ProductPrice" Margin="0,0,20,0" Padding="3"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="VAT (%):" Margin="0,0,10,10" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="1" Grid.Column="3" x:Name="Input_ProductVat" Margin="0,0,0,0" Padding="3"/>

                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Wyczyść Formularz" Width="130" Padding="6" Margin="0,0,10,0"
                            Background="#F0F0F0" Click="CleanProductForm_Click"/>
                                <Button Content="Dodaj Produkt" Width="120" Padding="5"
                            Background="#4CAF50" Foreground="White" FontWeight="Bold"
                            Click="AddProduct_Click"/>
                            </StackPanel>

                        </Grid>
                    </Border>

                    <!-- Tabela -->
                    <DataGrid Grid.Row="1"
                  x:Name="Products_DataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#F9F9F9"
                  GridLinesVisibility="All">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Jednostka" Binding="{Binding Unit}" Width="100"/>
                            <DataGridTextColumn Header="Cena Netto" Binding="{Binding PriceNetto}" Width="120"/>
                            <DataGridTextColumn Header="VAT %" Binding="{Binding Vat}" Width="80"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>
            </TabItem>

            <TabItem Header="Koszty" x:Name="Tab_Koszty">
                <Grid>
                    <TextBlock Text="Koszty" FontSize="20" Foreground="Gray" Margin="10,10,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Raporty" x:Name="Tab_Raporty">
                <Grid Margin="15">

                    <DataGrid x:Name="Reports_DataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              MouseDoubleClick="Reports_DataGrid_MouseDoubleClick">


                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Klient" Binding="{Binding Client.Name}" Width="*"/>
                            <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="150"/>
                            <DataGridTextColumn Header="Netto" Binding="{Binding TotalNetto}" Width="120"/>
                            <DataGridTextColumn Header="Brutto" Binding="{Binding TotalBrutto}" Width="120"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>